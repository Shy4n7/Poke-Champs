# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version.
#   Development personal preferences should be in .git/info/exclude.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different OS, it may cause dependency issues.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is recommended to include poetry.lock in version control.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, it is recommended to include pdm.lock in version control.
#.pdm.toml
#.pdm-plugins/
#pdm.lock

